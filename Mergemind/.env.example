# MergeMind Backend Environment Variables

# Server Port
PORT=3000

# GitHub App/OAuth (Create at github.com -> Settings -> Developer settings -> OAuth Apps)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_TOKEN=your_personal_access_token_with_repo_scope

# AI Provider (OpenRouter or OpenAI)
OPENAI_API_KEY=your_openrouter_or_openai_key

# Database
QDRANT_URL=http://localhost:6333 # For production, use Qdrant Cloud URL
QDRANT_API_KEY=your_qdrant_api_key

# Security
JWT_SECRET=your_secret_key_for_sessions

# URL Configuration (CRITICAL for production)
FRONTEND_URL=https://merge-mind-one.vercel.app # Change to your final frontend URL
BACKEND_URL=https://mergemind-1.onrender.com
